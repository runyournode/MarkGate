# .env_secret — MarkGate secrets
# Copy this file next to server_config.toml and fill in your values.

# ---------------------------------------------------------------------------
# S3 Storage Credentials
# ---------------------------------------------------------------------------
S3_ACCESS_KEY=changeme
S3_SECRET_KEY=changeme


# ---------------------------------------------------------------------------
# Var below are injected in backend_config.toml
# ---------------------------------------------------------------------------

# ---------------------------------------------------------------------------
# Client API Keys (per backend version)
# These are the Bearer tokens clients must send to access each version.
# ---------------------------------------------------------------------------
CLIENT_API_KEY_FOIL=changeme
CLIENT_API_KEY_FOIL_MINISTRAL_3_3B=changeme
CLIENT_API_KEY_FOIL_QWEN_3.5_27B=changeme
CLIENT_API_KEY_DOCLING=changeme
CLIENT_API_KEY_DOCLING_VL=changeme

# ---------------------------------------------------------------------------
# Upstream Backend API Keys
# ---------------------------------------------------------------------------
UPSTREAM_FOIL_API_KEY=changeme
UPSTREAM_DOCLING_API_KEY=changeme
UPSTREAM_VLM_API_KEY=changeme